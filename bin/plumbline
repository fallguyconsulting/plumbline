#!/usr/bin/env node

// SPDX-License-Identifier: Apache-2.0

const fs = require('fs');
const path = require('path');

const VERSION = '0.6.1';

const DOCSTRING_OPT_IN_MARKER = '@plumbline:allow-docstrings';

const MACHINE_DIRECTIVE_PATTERNS = {
  goDirective:                /^\s*go:/,
  golangciSuppression:        /^\s*nolint/,
  generatedFileHeader:        /^\s*Code generated/i,
  spdxLicenseLine:            /^\s*SPDX-/,
  pythonTypeIgnore:           /^\s*type:\s*ignore/,
  pythonNoqa:                 /^\s*noqa/,
  pylintSuppression:          /^\s*pylint:/,
  cPragma:                    /^\s*pragma\s/,
  eslintSuppression:          /^\s*eslint-(?:disable|enable)/,
  eslintGlobals:              /^\s*global\s/,
  tsSuppression:              /^\s*@?ts-(?:ignore|expect-error|nocheck)/,
  tsReference:                /^\s*\/\s*<reference\b/,
  tslintSuppression:          /^\s*tslint:/,
  biomeSuppression:           /^\s*biome-/,
  prettierSuppression:        /^\s*prettier-/,
  denoSuppression:            /^\s*deno-/,
  copyrightBanner:            /^!/,
  shebang:                    /^!\s*\//,
  copyrightLine:              /^\s*Copyright\b/,
  dualLicensedLine:           /^\s*Dual-licensed\b/i,
  licensedUnderLine:          /^\s*Licensed under\b/i,
  plumblineDirective:         /^\s*@plumbline:/,
};

const COMMENT_GRAMMARS = {
  '.go':   { line: '//', block: ['/*', '*/'], strings: ['"', "'", '`'] },
  '.ts':   { line: '//', block: ['/*', '*/'], strings: ['"', "'", '`'] },
  '.tsx':  { line: '//', block: ['/*', '*/'], strings: ['"', "'", '`'] },
  '.js':   { line: '//', block: ['/*', '*/'], strings: ['"', "'", '`'] },
  '.jsx':  { line: '//', block: ['/*', '*/'], strings: ['"', "'", '`'] },
  '.mjs':  { line: '//', block: ['/*', '*/'], strings: ['"', "'", '`'] },
  '.cjs':  { line: '//', block: ['/*', '*/'], strings: ['"', "'", '`'] },
  '.py':   { line: '#',  block: null,         strings: ['"', "'"] },
  '.rs':   { line: '//', block: ['/*', '*/'], strings: ['"'] },
  '.c':    { line: '//', block: ['/*', '*/'], strings: ['"'] },
  '.h':    { line: '//', block: ['/*', '*/'], strings: ['"'] },
  '.cc':   { line: '//', block: ['/*', '*/'], strings: ['"'] },
  '.cpp':  { line: '//', block: ['/*', '*/'], strings: ['"'] },
  '.hpp':  { line: '//', block: ['/*', '*/'], strings: ['"'] },
  '.java': { line: '//', block: ['/*', '*/'], strings: ['"'] },
  '.kt':   { line: '//', block: ['/*', '*/'], strings: ['"'] },
  '.sh':   { line: '#',  block: null,         strings: ['"', "'"] },
  '.bash': { line: '#',  block: null,         strings: ['"', "'"] },
  '.rb':   { line: '#',  block: null,         strings: ['"', "'"] },
};

const DEFAULT_IGNORE_PATTERNS = [
  'node_modules/',
  'vendor/',
  'dist/',
  'build/',
  'out/',
  '.git/',
  '.next/',
  'target/',
  '__pycache__/',
  'coverage/',
];

function validateCitation(entry, idx) {
  if (!entry || typeof entry !== 'object') {
    console.error(`error: .plumbline.json: citations[${idx}] must be an object`);
    process.exit(1);
  }
  if (typeof entry.tag !== 'string' || !entry.tag) {
    console.error(`error: .plumbline.json: citations[${idx}].tag must be a non-empty string`);
    process.exit(1);
  }
  const hasFile = typeof entry.file_template === 'string' && entry.file_template.length > 0;
  const hasGlob = typeof entry.appears_in_glob === 'string' && entry.appears_in_glob.length > 0;
  if (hasFile === hasGlob) {
    console.error(`error: .plumbline.json: citations[${idx}] (tag "${entry.tag}") must set exactly one of file_template or appears_in_glob`);
    process.exit(1);
  }
  if (hasFile && !entry.file_template.includes('{slug}')) {
    console.error(`error: .plumbline.json: citations[${idx}].file_template must contain the literal {slug}`);
    process.exit(1);
  }
}

function loadConfig(repoRoot) {
  const configPath = path.join(repoRoot, '.plumbline.json');
  let userConfig = {};
  if (fs.existsSync(configPath)) {
    try {
      userConfig = JSON.parse(fs.readFileSync(configPath, 'utf8'));
    } catch (err) {
      console.error(`error: failed to parse .plumbline.json: ${err.message}`);
      process.exit(1);
    }
  }
  const citations = [];
  if (Array.isArray(userConfig.citations)) {
    userConfig.citations.forEach((entry, idx) => {
      validateCitation(entry, idx);
      citations.push(entry);
    });
  }
  const ignore = [...DEFAULT_IGNORE_PATTERNS];
  if (Array.isArray(userConfig.ignore)) {
    for (const p of userConfig.ignore) {
      if (typeof p === 'string' && !ignore.includes(p)) ignore.push(p);
    }
  }
  const checks = {
    comment_hygiene: true,
    citation_resolution: true,
    ...(userConfig.checks || {}),
  };
  return { citations, ignore, checks };
}

function findRepoRoot(start) {
  let current = path.resolve(start);
  if (fs.statSync(current).isFile()) current = path.dirname(current);
  const startDir = current;
  while (true) {
    if (fs.existsSync(path.join(current, '.git'))) return current;
    if (fs.existsSync(path.join(current, '.plumbline.json'))) return current;
    const parent = path.dirname(current);
    if (parent === current) return startDir;
    current = parent;
  }
}

function shouldIgnore(filePath, repoRoot, ignorePatterns) {
  const rel = path.relative(repoRoot, filePath);
  for (const pattern of ignorePatterns) {
    const normalized = pattern.replace(/\/$/, '');
    if (rel === normalized) return true;
    if (rel.startsWith(normalized + '/')) return true;
    if (rel.includes('/' + normalized + '/')) return true;
  }
  return false;
}

function* walkFiles(target, repoRoot, ignorePatterns) {
  const stat = fs.statSync(target);
  if (stat.isFile()) {
    if (shouldIgnore(target, repoRoot, ignorePatterns)) return;
    if (COMMENT_GRAMMARS[path.extname(target)]) yield target;
    return;
  }
  const entries = fs.readdirSync(target, { withFileTypes: true });
  for (const entry of entries) {
    const full = path.join(target, entry.name);
    if (shouldIgnore(full, repoRoot, ignorePatterns)) continue;
    if (entry.isDirectory()) {
      yield* walkFiles(full, repoRoot, ignorePatterns);
    } else if (entry.isFile() && COMMENT_GRAMMARS[path.extname(entry.name)]) {
      yield full;
    }
  }
}

function extractRawComments(content, grammar) {
  const comments = [];
  let pos = 0;
  let line = 1;
  let inString = null;
  let blockStartLine = 0;
  let blockBuffer = null;

  function advance() {
    if (content[pos] === '\n') line++;
    pos++;
  }

  while (pos < content.length) {
    const c = content[pos];

    if (blockBuffer !== null) {
      const closeIdx = content.indexOf(grammar.block[1], pos);
      if (closeIdx < 0) {
        blockBuffer += content.slice(pos);
        pos = content.length;
        break;
      }
      blockBuffer += content.slice(pos, closeIdx);
      comments.push({ text: blockBuffer, line: blockStartLine, kind: 'block' });
      blockBuffer = null;
      while (pos < closeIdx + grammar.block[1].length) advance();
      continue;
    }

    if (inString) {
      if (c === '\\' && pos + 1 < content.length) { advance(); advance(); continue; }
      if (c === inString) inString = null;
      advance();
      continue;
    }

    if (grammar.strings.includes(c)) {
      inString = c;
      advance();
      continue;
    }

    if (grammar.line && content.startsWith(grammar.line, pos)) {
      const eol = content.indexOf('\n', pos);
      const end = eol < 0 ? content.length : eol;
      const text = content.slice(pos + grammar.line.length, end);
      comments.push({ text, line, kind: 'line' });
      while (pos < end) advance();
      continue;
    }

    if (grammar.block && content.startsWith(grammar.block[0], pos)) {
      blockStartLine = line;
      blockBuffer = '';
      for (let i = 0; i < grammar.block[0].length; i++) advance();
      continue;
    }

    advance();
  }

  return comments;
}

function mergeConsecutiveLineComments(rawComments) {
  const merged = [];
  for (const c of rawComments) {
    if (c.kind !== 'line') { merged.push(c); continue; }
    const last = merged[merged.length - 1];
    if (last && last.kind === 'line' && last.endLine === c.line - 1) {
      last.text += '\n' + c.text;
      last.endLine = c.line;
    } else {
      merged.push({ ...c, endLine: c.line });
    }
  }
  return merged;
}

function extractComments(content, grammar) {
  return mergeConsecutiveLineComments(extractRawComments(content, grammar));
}

function stripBlockCommentPrefix(line) {
  return line.replace(/^\s*\*\s?/, '').trim();
}

function firstSignificantLine(commentText) {
  const lines = commentText.split('\n')
    .map(stripBlockCommentPrefix)
    .filter((l) => l.length > 0);
  return lines[0] || '';
}

function isMachineDirective(firstLine) {
  for (const re of Object.values(MACHINE_DIRECTIVE_PATTERNS)) {
    if (re.test(firstLine)) return true;
  }
  return false;
}

function hasDocstringOptIn(content) {
  return content.includes(DOCSTRING_OPT_IN_MARKER);
}

function matchingCitation(firstLine, citations) {
  for (const c of citations) {
    if (firstLine.startsWith(c.tag)) return c;
  }
  return null;
}

const PURE_CITATION_SLUG_RE = /^\s+[a-z0-9][a-z0-9-]*\s*$/;

function isCleanCitationLine(line, citations) {
  for (const c of citations) {
    if (!line.startsWith(c.tag)) continue;
    const rest = line.slice(c.tag.length);
    if (PURE_CITATION_SLUG_RE.test(rest)) return true;
  }
  return false;
}

function isPureCitationBlock(comment, citations) {
  const lines = comment.text.split('\n')
    .map(stripBlockCommentPrefix)
    .filter((l) => l.length > 0);
  if (lines.length === 0) return false;
  for (const line of lines) {
    if (!isCleanCitationLine(line, citations)) return false;
  }
  return true;
}

function commentEndLine(c) {
  if (c.kind === 'line') return c.endLine || c.line;
  return c.line + c.text.split('\n').length - 1;
}

function nextNonCommentLine(allLines, fromLineNumber, grammar) {
  const max = Math.min(fromLineNumber + 5, allLines.length);
  for (let i = fromLineNumber; i < max; i++) {
    const raw = allLines[i] || '';
    const trimmed = raw.trim();
    if (trimmed === '') continue;
    if (grammar.line && trimmed.startsWith(grammar.line)) continue;
    if (grammar.block && (trimmed.startsWith(grammar.block[0]) || trimmed.startsWith('*'))) continue;
    return raw;
  }
  return null;
}

const JSDOC_DECL_PATTERNS = [
  /^\s*(?:export\s+)?(?:default\s+)?(?:async\s+)?function\s+\w+/,
  /^\s*(?:export\s+)?(?:default\s+)?(?:abstract\s+)?class\s+\w+/,
  /^\s*(?:export\s+)?interface\s+\w+/,
  /^\s*(?:export\s+)?type\s+\w+/,
  /^\s*(?:export\s+)?(?:async\s+)?(?:const|let|var)\s+\w+/,
  /^\s*(?:export\s+)?enum\s+\w+/,
  /^\s*(?:export\s+)?namespace\s+\w+/,
  /^\s*(?:public|private|protected|readonly)\s+(?:static\s+)?(?:async\s+)?\w+/,
  /^\s*(?:static\s+)?(?:async\s+)?\w+\s*\(/,
  /^\s*\w+\s*[:=?]/,
];

const JSDOC_GRAMMARS = new Set([
  COMMENT_GRAMMARS['.ts'],
  COMMENT_GRAMMARS['.tsx'],
  COMMENT_GRAMMARS['.js'],
  COMMENT_GRAMMARS['.jsx'],
  COMMENT_GRAMMARS['.mjs'],
  COMMENT_GRAMMARS['.cjs'],
]);

function isJsDocStyle(comment, allLines, grammar) {
  if (!JSDOC_GRAMMARS.has(grammar)) return false;
  if (comment.kind !== 'block') return false;
  const first = firstSignificantLine(comment.text);
  if (!first || !/^[A-Z]/.test(first)) return false;
  const nextLine = nextNonCommentLine(allLines, commentEndLine(comment), grammar);
  if (!nextLine) return false;
  return JSDOC_DECL_PATTERNS.some((re) => re.test(nextLine));
}

function isGoDocStyle(comment, allLines, grammar) {
  if (grammar !== COMMENT_GRAMMARS['.go']) return false;
  const first = firstSignificantLine(comment.text);
  const wordMatch = first.match(/^([A-Za-z_]\w*)/);
  if (!wordMatch) return false;
  const word = wordMatch[1];
  const nextLine = nextNonCommentLine(allLines, commentEndLine(comment), grammar);
  if (!nextLine) return false;
  if (word === 'Package') {
    const pkgMatch = first.match(/^Package\s+(\w+)/);
    if (pkgMatch && new RegExp(`^\\s*package\\s+${pkgMatch[1]}\\b`).test(nextLine)) return true;
  }
  if (/^\s*package\s+\w+/.test(nextLine)) return true;
  const esc = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const decls = [
    new RegExp(`^\\s*func\\s+${esc}\\b`),
    new RegExp(`^\\s*func\\s+\\([^)]*\\)\\s+${esc}\\b`),
    new RegExp(`^\\s*type\\s+${esc}\\b`),
    new RegExp(`^\\s*var\\s+${esc}\\b`),
    new RegExp(`^\\s*const\\s+${esc}\\b`),
    new RegExp(`^\\s*${esc}\\s+[\\w*\\[\\](){}.,]+`),
  ];
  return decls.some((re) => re.test(nextLine));
}

function checkCommentHygiene(filePath, content, grammar, config) {
  const violations = [];
  const allLines = content.split('\n');
  const docstringsAllowed = hasDocstringOptIn(content);
  for (const c of extractComments(content, grammar)) {
    const first = firstSignificantLine(c.text);
    if (!first) continue;
    if (isMachineDirective(first)) continue;
    if (isPureCitationBlock(c, config.citations)) continue;
    if (docstringsAllowed) {
      if (isJsDocStyle(c, allLines, grammar)) continue;
      if (isGoDocStyle(c, allLines, grammar)) continue;
    }
    const firstIsCitationTag = matchingCitation(first, config.citations) !== null;
    const message = firstIsCitationTag
      ? 'citation comment must be slug-only — each line is `@<tag>: <slug>` and nothing else (no em-dash tail, no continuation prose, no trailing punctuation; the design doc holds the explanation)'
      : 'comment is not permitted (not a machine directive, not a configured citation, no docstring opt-in)';
    violations.push({
      file: filePath,
      line: c.line,
      code: 'comment-hygiene',
      message,
    });
  }
  return violations;
}

function parseCitations(filePath, content, citations) {
  const found = [];
  const lines = content.split('\n');
  for (let i = 0; i < lines.length; i++) {
    const stripped = lines[i].replace(/^[\s/*#]+/, '');
    for (const c of citations) {
      if (stripped.startsWith(c.tag)) {
        const rest = stripped.slice(c.tag.length).trim();
        const slugMatch = rest.match(/^([^\s,;]+)/);
        if (slugMatch) {
          const slug = slugMatch[1].replace(/[.,;:]+$/, '');
          if (slug) found.push({ file: filePath, line: i + 1, tag: c.tag, slug, citation: c });
        }
      }
    }
  }
  return found;
}

function escapeForRegex(s) {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function globToRegex(glob) {
  let re = '^';
  let i = 0;
  while (i < glob.length) {
    const c = glob[i];
    if (c === '*') {
      if (glob[i + 1] === '*') {
        if (glob[i + 2] === '/') { re += '(?:.*\\/)?'; i += 3; continue; }
        re += '.*'; i += 2; continue;
      }
      re += '[^/]*';
      i++;
      continue;
    }
    if (c === '?') { re += '[^/]'; i++; continue; }
    if (/[.+()|^$\[\]{}\\]/.test(c)) { re += '\\' + c; i++; continue; }
    re += c;
    i++;
  }
  re += '$';
  return new RegExp(re);
}

function matchesAnyGlob(relPath, globSpec) {
  const globs = globSpec.split(',').map((g) => g.trim()).filter(Boolean);
  for (const g of globs) {
    if (globToRegex(g).test(relPath)) return true;
  }
  return false;
}

function collectAllFilesUnder(repoRoot, ignorePatterns) {
  const out = [];
  function walk(dir) {
    let entries;
    try { entries = fs.readdirSync(dir, { withFileTypes: true }); }
    catch (e) { return; }
    for (const entry of entries) {
      const full = path.join(dir, entry.name);
      if (shouldIgnore(full, repoRoot, ignorePatterns)) continue;
      if (entry.isDirectory()) walk(full);
      else if (entry.isFile()) out.push(full);
    }
  }
  walk(repoRoot);
  return out;
}

function checkCitationResolution(repoRoot, files, citations, ignorePatterns) {
  const violations = [];
  if (citations.length === 0) return violations;

  const allCitations = [];
  for (const file of files) {
    const content = fs.readFileSync(file, 'utf8');
    allCitations.push(...parseCitations(file, content, citations));
  }

  const globFileContents = {};
  const grepNeeded = citations.filter((c) => c.appears_in_glob);
  if (grepNeeded.length > 0) {
    const allFiles = collectAllFilesUnder(repoRoot, ignorePatterns);
    for (const c of grepNeeded) {
      globFileContents[c.tag] = [];
      for (const file of allFiles) {
        const rel = path.relative(repoRoot, file);
        if (matchesAnyGlob(rel, c.appears_in_glob)) {
          try { globFileContents[c.tag].push(fs.readFileSync(file, 'utf8')); }
          catch (e) {}
        }
      }
    }
  }

  const reportedGroupKeys = new Set();
  for (const cit of allCitations) {
    if (cit.citation.file_template) {
      const target = path.resolve(repoRoot, cit.citation.file_template.replace('{slug}', cit.slug));
      if (!fs.existsSync(target)) {
        violations.push({
          file: cit.file,
          line: cit.line,
          code: 'citation-unresolved',
          message: `${cit.tag} "${cit.slug}" does not resolve to ${path.relative(repoRoot, target)}`,
        });
      }
    } else if (cit.citation.appears_in_glob) {
      const groupKey = `${cit.tag}:${cit.slug}`;
      const contents = globFileContents[cit.tag] || [];
      const re = new RegExp(`\\b${escapeForRegex(cit.slug)}\\b`);
      const found = contents.some((c) => re.test(c));
      if (!found && !reportedGroupKeys.has(groupKey)) {
        reportedGroupKeys.add(groupKey);
        violations.push({
          file: cit.file,
          line: cit.line,
          code: 'citation-unresolved',
          message: `${cit.tag} "${cit.slug}" not found in any file matching ${cit.citation.appears_in_glob}`,
        });
      }
    }
  }
  return violations;
}

function formatViolation(v) {
  return `${v.file}:${v.line}: plumbline/${v.code}: ${v.message}`;
}

function slugCmd(prose) {
  if (!prose || !prose.trim()) {
    console.error('usage: plumbline slug "<prose description>"');
    process.exit(1);
  }
  console.log(generateSlug(prose));
  process.exit(0);
}

const SLUG_STOP_WORDS = new Set([
  'a', 'an', 'the', 'is', 'are', 'was', 'were', 'be', 'been', 'being',
  'has', 'have', 'had', 'do', 'does', 'did', 'will', 'would', 'should',
  'may', 'might', 'must', 'shall', 'can', 'could', 'of', 'in', 'on',
  'at', 'to', 'for', 'with', 'by', 'from', 'and', 'or', 'but', 'not',
  'no', 'as', 'that', 'this', 'these', 'those', 'it', 'its', 'they',
  'them', 'their', 'when', 'where', 'how', 'why', 'what', 'which',
  'who', 'whom', 'so', 'if', 'while', 'until', 'than', 'then', 'into',
  'about', 'over', 'under', 'between', 'among', 'before', 'after',
]);

function generateSlug(prose) {
  const cleaned = prose
    .toLowerCase()
    .replace(/[^\w\s-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  const words = cleaned.split(' ').filter((w) => w.length > 0 && !SLUG_STOP_WORDS.has(w));
  const significant = words.slice(0, 5);
  if (significant.length === 0) return 'unnamed';
  return significant.join('-').replace(/-+/g, '-');
}

const EXPLAIN_TOPICS = {
  'comment-hygiene': `comment-hygiene — comments are not permitted in source files except:

  1. Machine directives — license headers (SPDX, Copyright, Licensed under,
     Dual-licensed), lint suppressions (eslint-disable, ts-ignore / ts-expect-error
     / ts-nocheck, noqa, pylint:, tslint:, biome-, prettier-, deno-, nolint), build
     tags (go:), generated-file markers, C-pragmas, shebangs.

  2. Project-configured citation tags from .plumbline.json's "citations" array,
     used in slug-only form. Each entry declares { tag, file_template } or
     { tag, appears_in_glob }. A citation comment block consists of one or more
     adjacent lines, EACH of the form "@<tag>: <slug>" with nothing else after
     the slug — no em-dash tail, no continuation prose, no trailing punctuation.
     The slug names the design artifact; the design doc holds the explanation.
     Multiple clean citation lines stacked together (e.g. "@concept: cascade"
     immediately followed by "@story: parker") form one valid block. Each line's
     slug is independently checked for resolution. Mixing a citation line with
     a prose continuation line fails the whole block — the prose belongs in
     the design doc, the code carries the link only.

  3. Documentation comments — only when the file carries the opt-in marker
     ${DOCSTRING_OPT_IN_MARKER} as a comment. With the marker, JSDoc-style block
     comments (TS/JS) and GoDoc-style line comments adjacent to a declaration
     are exempt. Without the marker, they are not.

  Everything else is residue. Convert the load-bearing information into a
  name, a type, an assertion, a test, or delete the comment.`,

  'citation-unresolved': `citation-unresolved — a comment carries a citation tag declared in
.plumbline.json's "citations" but its slug does not resolve.

  For file_template citations: the substituted path does not exist on disk.
  Fix by correcting the slug, creating the artifact at the target path, or
  removing the citation.

  For appears_in_glob citations: the slug is not present (word-boundary
  match) in any file matching the glob. Fix by adding a reference to the
  slug in one of the matching files, or correcting the slug.`,

  citations: `citations — the .plumbline.json mechanism for declaring
project-specific structured-tag exemptions.

  Each entry takes the shape:
    { "tag": "@concept:",  "file_template": ".ok-planner/design/concepts/{slug}.md" }
  or:
    { "tag": "@my-invariant:", "appears_in_glob": "**/*_test.*,test_*.py" }

  Exactly one of file_template or appears_in_glob must be set. file_template
  must contain the literal {slug}, which is substituted with the parsed slug
  to form a repo-rooted path that must exist. appears_in_glob is a
  comma-separated set of repo-rooted globs (** and * supported); the slug
  must appear (word-boundary match) in at least one matching file.

  Citation comments are slug-only at the code site. Each line in a citation
  comment block has the form "@<tag>: <slug>" with nothing else after the
  slug — no em-dash tail, no continuation prose, no trailing punctuation.
  The slug names the design artifact (or the invariant); the explanation
  lives in the artifact itself, not at the code site. Multiple clean
  citation lines may stack as one block, but mixing a citation line with
  prose continuation fails comment-hygiene.

  Slug format: kebab-case ([a-z0-9][a-z0-9-]*). Lowercase, digits, hyphens.

  Plumbline ships zero default citations. Projects that need design-artifact
  tracing add the entries themselves — typically by running plumbline starter,
  which detects .ok-planner/ and emits the canonical concept/story/decision
  entries.`,

  [DOCSTRING_OPT_IN_MARKER]: `${DOCSTRING_OPT_IN_MARKER} — file-level opt-in marker
that enables JSDoc/GoDoc-style documentation comments in the file.

  Place this marker as a comment anywhere in the file (typically near the
  top, after the license header):

    // ${DOCSTRING_OPT_IN_MARKER}        (for // languages)
    # ${DOCSTRING_OPT_IN_MARKER}         (for # languages)

  With the marker present, JSDoc-style block comments adjacent to a TS/JS
  declaration (function, class, interface, type, const/let/var, enum,
  namespace, methods, fields) and GoDoc-style line comments adjacent to a
  Go declaration (func, type, var, const, package) are exempt from the
  comment-hygiene check. Without the marker, no documentation comments are
  allowed.

  The marker is intended for files that document a public API. Internal
  files do not need it.`,
};

function explainCmd(topic) {
  if (!topic) {
    console.log('usage: plumbline explain <topic>');
    console.log('');
    console.log('available topics:');
    for (const t of Object.keys(EXPLAIN_TOPICS)) console.log(`  ${t}`);
    process.exit(0);
  }
  const entry = EXPLAIN_TOPICS[topic];
  if (!entry) {
    console.error(`unknown topic: ${topic}`);
    console.error(`run 'plumbline explain' to list available topics`);
    process.exit(1);
  }
  console.log(entry);
  process.exit(0);
}

const CI_TEMPLATES = {
  github: `name: plumbline
on:
  pull_request:
  push:
    branches: [main]

jobs:
  plumbline:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: install plumbline
        run: |
          git clone --depth 1 https://github.com/fallguyconsulting/plumbline /tmp/plumbline
      - name: lint
        run: node /tmp/plumbline/bin/plumbline .
      - name: budget check
        if: hashFiles('.plumbline-budget.json') != ''
        run: node /tmp/plumbline/bin/plumbline budget check
`,
  gitlab: `plumbline:
  image: node:20
  stage: test
  before_script:
    - git clone --depth 1 https://github.com/fallguyconsulting/plumbline /tmp/plumbline
  script:
    - node /tmp/plumbline/bin/plumbline .
    - test -f .plumbline-budget.json && node /tmp/plumbline/bin/plumbline budget check || true
  rules:
    - if: $CI_PIPELINE_SOURCE == "merge_request_event"
    - if: $CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH
`,
  'pre-commit': `repos:
  - repo: local
    hooks:
      - id: plumbline
        name: plumbline
        entry: node /path/to/plumbline/bin/plumbline
        language: system
        pass_filenames: true
        types: [go, javascript, ts, python, rust]
`,
};

function ciCmd(platform) {
  if (!platform || !CI_TEMPLATES[platform]) {
    console.log('usage: plumbline ci <platform>');
    console.log('');
    console.log('available platforms:');
    for (const p of Object.keys(CI_TEMPLATES)) console.log(`  ${p}`);
    process.exit(platform ? 1 : 0);
  }
  console.log(CI_TEMPLATES[platform]);
  process.exit(0);
}

function budgetCmd(action, target) {
  const allowed = ['save', 'check'];
  if (!allowed.includes(action)) {
    console.error('usage: plumbline budget save|check [path]');
    process.exit(1);
  }
  if (!fs.existsSync(target)) {
    console.error(`error: target not found: ${target}`);
    process.exit(1);
  }
  const { violations, repoRoot } = runLint(target);
  const count = violations.length;
  const byCheck = {};
  for (const v of violations) byCheck[v.code] = (byCheck[v.code] || 0) + 1;
  const budgetPath = path.join(repoRoot, '.plumbline-budget.json');

  if (action === 'save') {
    const payload = { count, by_check: byCheck };
    fs.writeFileSync(budgetPath, JSON.stringify(payload, null, 2) + '\n');
    console.log(`saved baseline: ${count} violation(s) at ${path.relative(repoRoot, budgetPath) || '.plumbline-budget.json'}`);
    for (const [code, n] of Object.entries(byCheck)) console.log(`  ${code}: ${n}`);
    process.exit(0);
  }

  if (!fs.existsSync(budgetPath)) {
    console.error(`error: no baseline at ${path.relative(repoRoot, budgetPath) || '.plumbline-budget.json'} — run 'plumbline budget save' first`);
    process.exit(1);
  }
  const baseline = JSON.parse(fs.readFileSync(budgetPath, 'utf8'));
  const baselineCount = baseline.count || 0;
  if (count > baselineCount) {
    console.error(`plumbline budget: ${count} violation(s) exceeds baseline ${baselineCount} (+${count - baselineCount})`);
    for (const [code, n] of Object.entries(byCheck)) {
      const base = (baseline.by_check && baseline.by_check[code]) || 0;
      if (n > base) console.error(`  ${code}: ${n} (was ${base}, +${n - base})`);
    }
    process.exit(2);
  }
  if (count < baselineCount) {
    console.log(`plumbline budget: ${count} violation(s) — ${baselineCount - count} below baseline (run 'plumbline budget save' to ratchet)`);
  } else {
    console.log(`plumbline budget: ${count} violation(s) — at baseline`);
  }
  process.exit(0);
}

function patternsCmd(target) {
  if (!fs.existsSync(target)) {
    console.error(`error: target not found: ${target}`);
    process.exit(1);
  }
  const { violations } = runLint(target);
  if (violations.length === 0) {
    console.log('plumbline: no violations to cluster');
    process.exit(0);
  }
  const fileCache = {};
  const buckets = {};
  for (const v of violations) {
    const key = patternKey(v, fileCache);
    if (!buckets[key]) buckets[key] = { code: v.code, signature: key, count: 0, samples: [] };
    buckets[key].count++;
    if (buckets[key].samples.length < 3) buckets[key].samples.push(`${v.file}:${v.line}`);
  }
  const sorted = Object.values(buckets).sort((a, b) => b.count - a.count);
  console.log(`plumbline patterns: ${violations.length} violation(s) in ${sorted.length} cluster(s)`);
  console.log('');
  for (const b of sorted) {
    console.log(`  [${b.count}x] ${b.code}: ${b.signature}`);
    for (const s of b.samples) console.log(`    ${s}`);
    if (b.count > b.samples.length) console.log(`    ... and ${b.count - b.samples.length} more`);
    console.log('');
  }
  process.exit(sorted.length > 0 ? 2 : 0);
}

function patternKey(v, fileCache) {
  if (v.code === 'citation-unresolved') {
    const m = v.message.match(/^(@[A-Za-z0-9_:-]+)\s+"([^"]+)"/);
    return m ? `tag:${m[1]}` : 'citation-unresolved';
  }
  if (v.code === 'comment-hygiene') {
    return commentHygieneShape(v, fileCache || {});
  }
  return v.code;
}

function commentHygieneShape(v, fileCache) {
  if (!fileCache[v.file]) {
    try {
      fileCache[v.file] = fs.readFileSync(v.file, 'utf8').split('\n');
    } catch (e) {
      return 'disallowed-prose';
    }
  }
  const lines = fileCache[v.file];
  if (!lines || v.line < 1 || v.line > lines.length) return 'disallowed-prose';
  const startLine = lines[v.line - 1] || '';
  const blockText = lines.slice(v.line - 1, Math.min(v.line + 4, lines.length)).join(' ');
  const stripped = startLine.replace(/^[\s/*#]+/, '').trim();

  if (startLine.trim().length >= 8 && /^[\s/*#=\-+~_.]+$/.test(startLine) && !/[A-Za-z0-9]/.test(stripped)) {
    return 'divider';
  }
  if (/\b(Copyright|All rights reserved|Licensed under|SPDX-License)/i.test(blockText)) {
    return 'license-fragment';
  }
  if (/\b(TODO|FIXME|HACK|XXX)\b/.test(blockText)) {
    return 'todo-marker';
  }
  if (isLikelyCode(stripped)) {
    return 'commented-out-code';
  }
  const ext = path.extname(v.file).toLowerCase();
  if (['.go', '.ts', '.tsx', '.js', '.jsx'].includes(ext)) {
    for (let i = v.line; i < Math.min(v.line + 10, lines.length); i++) {
      const ln = (lines[i] || '').trim();
      if (!ln) continue;
      if (ln.startsWith('//') || ln.startsWith('/*') || ln.startsWith('*')) continue;
      if (ext === '.go' && /^(func|type|var|const|package|import)\b/.test(ln)) return 'doc-residue';
      if (['.ts', '.tsx', '.js', '.jsx'].includes(ext) &&
          /^(export\s+|async\s+)?(function|class|const|let|var|interface|type|enum|namespace)\b/.test(ln)) {
        return 'doc-residue';
      }
      break;
    }
  }
  return 'disallowed-prose';
}

function isLikelyCode(text) {
  if (!text) return false;
  if (/^(func|var|const|if|for|return|package|import|type|class|function|let|else|switch|case|default|break|continue|defer|go|select)\b/.test(text)) return true;
  if (/^\w+\s*:=/.test(text)) return true;
  if (/^[a-zA-Z_$][\w$]*\s*\(/.test(text) && /[){};]/.test(text)) return true;
  if (/^[{}]$/.test(text)) return true;
  return false;
}

const SUGGEST_HEURISTICS = [
  { match: /\b(TODO|FIXME|HACK|XXX)\b/, action: 'delete the comment — promote to an issue tracker if the work still matters', why: 'TODO marker' },
  { match: /\b(must|always|never|requires|forbidden|mandatory|MUST|MUST NOT)\b/, action: 'convert to an assertion with a message, or to a test that fails when the rule is violated', why: 'imperative requirement; the rule should be enforced by code, not narrated' },
  { match: /\b(deliberate|intentional|on purpose|NOT batched|sequential on purpose|do not\b|don't )/i, action: 'encode the intent in a function/variable name, or in a test that fails if the "obvious" alternative is substituted', why: 'intentionality belongs in a test or a name' },
  { match: /\b(handle|handles?) the (case|error|failure)/i, action: 'delete the comment', why: 'generation residue' },
  { match: /\b(this|the|we) (set|sets|get|gets|return|returns|compute|computes|call|calls|invoke|invokes|create|creates)\b/i, action: 'delete the comment', why: 'restates what the code does' },
  { match: /\bSee\s+(also|the|\w+\.\w+)/i, action: 'inline the relevant constraint as a name, type, or assertion; delete the prose pointer', why: 'cross-reference prose drifts; encode the dependency in code' },
];

function suggestCmd(target) {
  if (!fs.existsSync(target)) {
    console.error(`error: target not found: ${target}`);
    process.exit(1);
  }
  const { violations } = runLint(target);
  if (violations.length === 0) {
    console.log('plumbline: no violations to suggest fixes for');
    process.exit(0);
  }
  const fileCache = {};
  let suggested = 0;
  for (const v of violations) {
    const suggestion = suggestForViolation(v, fileCache);
    if (!suggestion) continue;
    suggested++;
    console.log(`${v.file}:${v.line}: ${v.code}`);
    console.log(`  suggestion: ${suggestion.action}`);
    console.log(`  rationale:  ${suggestion.why}`);
    console.log('');
  }
  console.log(`plumbline suggest: ${suggested} of ${violations.length} violation(s) have an automated suggestion`);
  process.exit(0);
}

function suggestForViolation(v, fileCache) {
  if (v.code === 'comment-hygiene') {
    if (!fileCache[v.file]) {
      try {
        fileCache[v.file] = fs.readFileSync(v.file, 'utf8').split('\n');
      } catch (e) {
        return null;
      }
    }
    const lines = fileCache[v.file];
    const commentText = lines.slice(v.line - 1, Math.min(v.line + 4, lines.length)).join(' ');
    for (const h of SUGGEST_HEURISTICS) {
      if (h.match.test(commentText)) return { action: h.action, why: h.why };
    }
    return {
      action: 'delete the comment',
      why: 'no recognized shape; the default action under plumbline is to delete (comments are not permitted unless they are a machine directive, a configured citation, or a docstring in an opt-in file)',
    };
  }
  if (v.code === 'citation-unresolved') {
    const m = v.message.match(/^(@[A-Za-z0-9_:-]+)\s+"([^"]+)"/);
    if (!m) return null;
    return {
      action: `either correct the slug ("${m[2]}"), create the artifact the citation's resolution rule expects, or remove the citation`,
      why: 'the citation tag declares that its slug must resolve to something the project can verify; broken citations rot',
    };
  }
  return null;
}

function starterCmd(target) {
  if (!fs.existsSync(target)) {
    console.error(`error: target not found: ${target}`);
    process.exit(1);
  }
  const repoRoot = path.resolve(target);
  const projectIgnores = new Set();
  const hasGo = fs.existsSync(path.join(repoRoot, 'go.mod'));
  const hasNode = fs.existsSync(path.join(repoRoot, 'package.json'));
  const hasOkPlanner = fs.existsSync(path.join(repoRoot, '.ok-planner'));

  if (hasOkPlanner) projectIgnores.add('.ok-planner/');
  for (const candidate of ['gen/', 'generated/', 'proto/gen/', 'pb/', 'mocks/', 'fixtures/']) {
    if (existsSomewhere(repoRoot, candidate)) projectIgnores.add(candidate);
  }
  if (hasGo) {
    for (const c of ['lib/protocols/proto/v1/gen/', 'internal/gen/']) {
      if (existsSomewhere(repoRoot, c)) projectIgnores.add(c);
    }
  }
  if (hasNode) {
    for (const c of ['.next/', '.turbo/', 'storybook-static/']) {
      if (existsSomewhere(repoRoot, c)) projectIgnores.add(c);
    }
  }

  const citations = [];
  if (hasOkPlanner) {
    citations.push({ tag: '@concept:',  file_template: '.ok-planner/design/concepts/{slug}.md' });
    citations.push({ tag: '@story:',    file_template: '.ok-planner/design/stories/{slug}.md' });
    citations.push({ tag: '@decision:', file_template: '.ok-planner/design/decisions/{slug}.md' });
  }

  const cfg = {
    citations,
    ignore: Array.from(projectIgnores),
    checks: {
      comment_hygiene: true,
      citation_resolution: true,
    },
  };
  console.log(JSON.stringify(cfg, null, 2));
  console.log('');
  console.error('# Suggested .plumbline.json above. Save as .plumbline.json at the repo root.');
  console.error(`# Detected: ${hasGo ? 'Go module ' : ''}${hasNode ? 'Node package ' : ''}${hasOkPlanner ? 'ok-planner ' : ''}`.trim());
  process.exit(0);
}

function existsSomewhere(root, suffix) {
  const trim = suffix.replace(/\/$/, '');
  try {
    const result = require('child_process').execSync(
      `find . -maxdepth 6 -type d -name ${JSON.stringify(path.basename(trim))} 2>/dev/null | head -1`,
      { cwd: root, encoding: 'utf8' }
    ).trim();
    return result.length > 0;
  } catch (e) {
    return false;
  }
}

function doctorCmd(target) {
  if (!fs.existsSync(target)) {
    console.error(`error: target not found: ${target}`);
    process.exit(1);
  }
  const repoRoot = findRepoRoot(target);
  const checks = [];
  const cfgPath = path.join(repoRoot, '.plumbline.json');
  if (!fs.existsSync(cfgPath)) {
    checks.push(['warn', `no .plumbline.json at ${repoRoot} — using defaults (run 'plumbline starter' for a project-shaped starter)`]);
  } else {
    try {
      JSON.parse(fs.readFileSync(cfgPath, 'utf8'));
      const cfg = loadConfig(repoRoot);
      const enabled = Object.keys(cfg.checks).filter((k) => cfg.checks[k]).length;
      const total = Object.keys(cfg.checks).length;
      checks.push(['ok', `.plumbline.json parses (${enabled} of ${total} checks enabled; ${cfg.citations.length} citation tag(s) declared)`]);
    } catch (e) {
      checks.push(['fail', `.plumbline.json is malformed: ${e.message}`]);
    }
  }
  const cheatsheet = path.join(repoRoot, '.claude', 'rules', 'plumbline-cheatsheet.md');
  if (fs.existsSync(cheatsheet)) checks.push(['ok', `cheatsheet committed at ${path.relative(repoRoot, cheatsheet)}`]);
  else checks.push(['warn', `no cheatsheet at ${path.relative(repoRoot, cheatsheet)} — run '/plumbline:affirm' to materialize it`]);
  const budget = path.join(repoRoot, '.plumbline-budget.json');
  if (fs.existsSync(budget)) checks.push(['ok', `budget baseline at ${path.relative(repoRoot, budget)}`]);
  else checks.push(['info', `no .plumbline-budget.json — optional, used by 'plumbline budget check' in CI`]);
  const settings = path.join(repoRoot, '.claude', 'settings.json');
  if (fs.existsSync(settings)) {
    try {
      const s = JSON.parse(fs.readFileSync(settings, 'utf8'));
      const enabled = (s.enabledPlugins && Object.keys(s.enabledPlugins).some((k) => k.startsWith('plumbline@'))) || false;
      if (enabled) checks.push(['ok', 'plumbline plugin enabled in .claude/settings.json']);
      else checks.push(['warn', `plumbline plugin not enabled in .claude/settings.json — install via '/plugin install plumbline@fallguy'`]);
    } catch (e) {
      checks.push(['warn', `.claude/settings.json present but unparseable`]);
    }
  } else {
    checks.push(['info', `no .claude/settings.json — plugin enablement check skipped`]);
  }

  let fails = 0;
  for (const [status, msg] of checks) {
    const symbol = status === 'ok' ? '✓' : status === 'fail' ? '✗' : status === 'warn' ? '!' : '·';
    console.log(`  ${symbol} ${msg}`);
    if (status === 'fail') fails++;
  }
  console.log('');
  console.log(`plumbline doctor: ${fails === 0 ? 'healthy' : `${fails} failure(s)`}`);
  process.exit(fails > 0 ? 1 : 0);
}

function runLint(target) {
  const repoRoot = findRepoRoot(target);
  const config = loadConfig(repoRoot);
  const files = [];
  for (const f of walkFiles(path.resolve(target), repoRoot, config.ignore)) {
    files.push(f);
  }
  const violations = [];
  if (config.checks.comment_hygiene) {
    for (const file of files) {
      const content = fs.readFileSync(file, 'utf8');
      const grammar = COMMENT_GRAMMARS[path.extname(file)];
      violations.push(...checkCommentHygiene(file, content, grammar, config));
    }
  }
  if (config.checks.citation_resolution) {
    violations.push(...checkCitationResolution(repoRoot, files, config.citations, config.ignore));
  }
  violations.sort((a, b) => a.file.localeCompare(b.file) || a.line - b.line);
  return { violations, files, repoRoot, config };
}

function parseLineRanges(spec) {
  if (!spec) return null;
  const ranges = [];
  for (const part of spec.split(',')) {
    const m = part.trim().match(/^(\d+)(?:-(\d+))?$/);
    if (!m) continue;
    const start = parseInt(m[1], 10);
    const end = m[2] ? parseInt(m[2], 10) : start;
    if (end >= start) ranges.push([start, end]);
  }
  return ranges;
}

function lineInRanges(line, ranges) {
  for (const [a, b] of ranges) if (line >= a && line <= b) return true;
  return false;
}

function lintCmd(target, opts) {
  if (!fs.existsSync(target)) {
    console.error(`error: target not found: ${target}`);
    process.exit(1);
  }
  let { violations } = runLint(target);
  if (opts && opts.lines) {
    violations = violations.filter((v) => lineInRanges(v.line, opts.lines));
  }
  for (const v of violations) console.log(formatViolation(v));
  if (violations.length > 0) {
    console.error(`plumbline: ${violations.length} violation(s)`);
    process.exit(2);
  }
  process.exit(0);
}

const SUBCOMMANDS = {
  lint: (args) => lintCmd(args[0] || process.cwd()),
  patterns: (args) => patternsCmd(args[0] || process.cwd()),
  budget: (args) => budgetCmd(args[0], args[1] || process.cwd()),
  suggest: (args) => suggestCmd(args[0] || process.cwd()),
  slug: (args) => slugCmd(args.join(' ')),
  starter: (args) => starterCmd(args[0] || process.cwd()),
  doctor: (args) => doctorCmd(args[0] || process.cwd()),
  explain: (args) => explainCmd(args[0]),
  ci: (args) => ciCmd(args[0]),
  version: () => { console.log(VERSION); process.exit(0); },
};

function main() {
  const raw = process.argv.slice(2);
  const opts = {};
  const args = [];
  for (let i = 0; i < raw.length; i++) {
    const a = raw[i];
    if (a === '--lines' && i + 1 < raw.length) {
      opts.lines = parseLineRanges(raw[++i]);
    } else if (a.startsWith('--lines=')) {
      opts.lines = parseLineRanges(a.slice('--lines='.length));
    } else {
      args.push(a);
    }
  }
  if (args.length === 0) return lintCmd(process.cwd(), opts);
  const head = args[0];
  if (SUBCOMMANDS[head]) return SUBCOMMANDS[head](args.slice(1));
  return lintCmd(head, opts);
}

main();
